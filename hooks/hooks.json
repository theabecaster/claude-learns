{
  "hooks": [
    {
      "event": "UserPromptSubmit",
      "type": "command",
      "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/detect-correction.py"
    },
    {
      "event": "SessionStart",
      "type": "command",
      "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/session-count.sh"
    },
    {
      "event": "SessionEnd",
      "type": "command",
      "async": true,
      "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/audit.py"
    }
  ]
}

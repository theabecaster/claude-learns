{
  "hooks": [
    {"event": "UserPromptSubmit", "type": "command", "command": "npx --yes tsx ${CLAUDE_PLUGIN_ROOT}/hooks/detect-correction.ts"},
    {"event": "SessionStart", "type": "command", "command": "npx --yes tsx ${CLAUDE_PLUGIN_ROOT}/hooks/session-count.ts"},
    {"event": "SessionEnd", "type": "command", "async": true, "command": "npx --yes tsx ${CLAUDE_PLUGIN_ROOT}/hooks/audit.ts"}
  ]
}

{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "tsx ${CLAUDE_PLUGIN_ROOT}/hooks/detect-correction.ts"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "tsx ${CLAUDE_PLUGIN_ROOT}/hooks/session-count.ts"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "async": true,
            "command": "tsx ${CLAUDE_PLUGIN_ROOT}/hooks/audit.ts"
          }
        ]
      }
    ]
  }
}
